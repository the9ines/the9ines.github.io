---
import '../styles/global.css'
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link id="dynamic-favicon" rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Evan Oberfelder — software engineer, founder of The 9ine's Agency" />
		<meta property="og:title" content="evanacci" />
		<meta property="og:description" content="Evan Oberfelder — software engineer, founder of The 9ine's Agency" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://evanacci.com" />
		<meta name="twitter:card" content="summary" />
		<title>evanacci</title>
	</head>
	<body>
		<div class="min-h-screen bg-black flex flex-col items-center justify-center relative">
			<div class="text-center">
				<a
					href="https://github.com/Evanacci"
					target="_blank"
					rel="noopener noreferrer"
					class="text-sm font-mono tracking-wide animate-pulse motion-safe:animate-pulse text-gradient-lime hover:opacity-80 transition-opacity"
				>
					evanacci
				</a>
			</div>

			<div class="absolute bottom-8 text-center">
				<p style="font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 9px; letter-spacing: 0.05em; color: rgba(255,255,255,0.2);">
					by <a
						href="https://the9ines.com"
						target="_blank"
						class="credit-link"
					>the9ines</a>
				</p>
			</div>
		</div>

		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "Person",
					"@id": "https://the9ines.com/#person",
					"name": "Evan Oberfelder",
					"alternateName": "evanacci",
					"jobTitle": "Owner",
					"url": "https://the9ines.com",
					"worksFor": { "@id": "https://the9ines.com/#organization" },
					"address": {
						"@type": "PostalAddress",
						"addressLocality": "Austin",
						"addressRegion": "TX",
						"addressCountry": "US"
					},
					"sameAs": [
						"https://github.com/Evanacci",
						"https://the9ines.com",
						"https://www.linkedin.com/in/evan-oberfelder-1024b777/",
						"https://www.instagram.com/0xevan/",
						"https://www.facebook.com/evan.oberfelder.37",
						"https://github.com/the9ines"
					]
				},
				{
					"@type": "Organization",
					"@id": "https://the9ines.com/#organization",
					"name": "The 9ine's Agency",
					"url": "https://the9ines.com",
					"logo": "https://the9ines.com/favicon.svg",
					"founder": { "@id": "https://the9ines.com/#person" },
					"description": "Digital agency specializing in web development, e-commerce, and SEO. Based in Austin, Texas.",
					"address": {
						"@type": "PostalAddress",
						"addressLocality": "Austin",
						"addressRegion": "TX",
						"addressCountry": "US"
					}
				},
				{
					"@type": "WebSite",
					"@id": "https://evanacci.github.io/#website",
					"name": "evanacci",
					"url": "https://evanacci.github.io",
					"author": { "@id": "https://the9ines.com/#person" }
				}
			]
		})} />
		<script>
			(() => {
				const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
				let animationInterval: ReturnType<typeof setInterval>;

				const createFaviconAnimation = () => {
					clearInterval(animationInterval);

					if (motionQuery.matches) {
						const svg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128"><rect width="128" height="128" fill="#000"/><text x="64" y="96" text-anchor="middle" font-family="ui-monospace,monospace" font-size="100" font-weight="700" fill="#a4e203">e</text></svg>`;
						const link = document.getElementById("dynamic-favicon") as HTMLLinkElement;
						if (link) { link.href = `data:image/svg+xml;base64,${btoa(svg)}`; }
						return;
					}

					const frames: string[] = [];
					const numFrames = 20;
					// Pulse curve: brightness oscillates for the lime green
					const pulseCurve = [
						65, 70, 75, 80, 85,
						85, 82, 80, 77, 75,
						72, 70, 67, 65, 62,
						60, 60, 62, 65, 65
					];

					for (let i = 0; i < numFrames; i++) {
						const l = pulseCurve[i];
						const color = `hsl(80, 97%, ${l}%)`;
						const svg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128"><rect width="128" height="128" fill="#000"/><text x="64" y="96" text-anchor="middle" font-family="ui-monospace,monospace" font-size="100" font-weight="700" fill="${color}">e</text></svg>`;
						frames.push(`data:image/svg+xml;base64,${btoa(svg)}`);
					}

					let frameIndex = 0;
					animationInterval = setInterval(() => {
						const link = document.getElementById("dynamic-favicon") as HTMLLinkElement;
						if (link) { link.href = frames[frameIndex]; }
						frameIndex = (frameIndex + 1) % frames.length;
					}, 100);
				};

				createFaviconAnimation();
				motionQuery.addEventListener('change', createFaviconAnimation);
			})();
		</script>
	</body>
</html>
